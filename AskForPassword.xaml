<Window x:Class="UnlockWarning.AskForPassword"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="请输入管理员密码"
        Height="265"
        Width="800"
        Icon="{Binding RelativeSource={RelativeSource Self}, Path=Icon}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="85"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>     <!-- TextBox 占满剩余空间 -->
            <ColumnDefinition Width="Auto"/>  <!-- Button 自动宽度 -->
        </Grid.ColumnDefinitions>

        <!-- Label1 -->
        <Label x:Name="label1"
               Content="管理员密码:"
               FontFamily="思源黑体 CN Medium"
               FontWeight="Bold"
               FontSize="14"
               HorizontalAlignment="Left"
               VerticalAlignment="Center"
               Margin="44,0,0,0"/>

        <!-- Label2 -->
        <Label x:Name="label2"
               Grid.Row="0"
               FontFamily="Microsoft YaHei UI"
               FontSize="12"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Margin="180,0,0,0"
               Width="551"/>

        <!-- TextBox -->
        <TextBox x:Name="textBox1"
                 Grid.Row="1"
                 Grid.Column="0"
                 Margin="0,10,0,0"
                 VerticalContentAlignment="Center"
                 Height="Auto"
                 FontSize="16"
                 MinHeight="0"
                 Padding="3 2"
                 VerticalAlignment="Top"
                 TextWrapping="Wrap"/>

        <!-- Button -->
        <Button x:Name="button1"
                Grid.Row="1"
                Grid.Column="1"
                Content="验证"
                Width="121"
                Height="{Binding ElementName=textBox1, Path=ActualHeight}"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,0,0"
                FontSize="16"
                Padding="10 3 "
                Click="button1_Click"/>
    </Grid>
</Window>