<Window x:Class="UnlockWarning.sha_256"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SHA256值"
        Height="265"
        Width="800"
        Icon="{Binding RelativeSource={RelativeSource Self}, Path=Icon}">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="85"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Label1 -->
        <Label x:Name="label1"
               Content="SHA256值："
               FontFamily="思源黑体 CN Medium"
               FontWeight="Bold"
               FontSize="14"
               HorizontalAlignment="Left"
               VerticalAlignment="Center"
               Margin="44,0,0,0"/>

        <!-- Label2 -->
        <Label x:Name="label2"
               Grid.Row="0"
               FontFamily="Microsoft YaHei UI"
               FontSize="12"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Margin="180,0,0,0"
               Width="551"/>

        <!-- TextBox -->
        <TextBox x:Name="textBox1"
                 Grid.Row="1"
                 Margin="0,10,0,0"
                 Height="53"
                 VerticalAlignment="Top"
                 TextWrapping="Wrap"
                 AcceptsReturn="True"/>

        <!-- Button -->
        <Button x:Name="button1"
                Grid.Row="1"
                Content="校验"
                Width="121"
                Height="53"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,10,0,0"
                Click="button1_Click"/>
    </Grid>
</Window>