<Window x:Class="UnlockWarning.NotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:UnlockWarning"
        mc:Ignorable="d"
        Topmost="True"
        ShowInTaskbar="False"
        Title="NotificationWindow" Height="150" Width="100" Background="Transparent" ResizeMode="NoResize" WindowStyle="None" AllowsTransparency="True">
    <Border Background="#ffffff" CornerRadius="10" BorderThickness="2" BorderBrush="#ebedf3" Padding="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" /> <!-- 占满整个高度 -->
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            
            <Button Content="显示主界面" Grid.Row="0" Style="{StaticResource NotifyButton}" HorizontalAlignment="Stretch" Click="Show_Click"/>
            <Button Content="退出" Grid.Row="1" Style="{StaticResource NotifyButton}" HorizontalAlignment="Stretch" Click="Exit_Click"/>
        </Grid>
    </Border>
</Window>
