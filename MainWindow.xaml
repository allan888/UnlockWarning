<Window x:Class="UnlockWarning.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CJY安全卫士"
        Height="450"
        Width="800"
        Icon="{Binding RelativeSource={RelativeSource Self}, Path=Icon}">
    <Grid>
        <!-- 按钮 -->
        <Button x:Name="button1"
                Content="打开/关上"
                FontFamily="思源黑体 CN Medium"
                FontWeight="Bold"
                FontSize="14"
                Width="280"
                Height="89"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="258,12,0,0"
                Click="Button_Click"/>

        <!-- 图片框 -->
        <Image x:Name="pictureBox1"
               Width="691"
               Height="237"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Margin="57,133,0,0"
               Stretch="Uniform"/>
    </Grid>
</Window>