<Window x:Class="GenerateLicense.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="许可证生成器" Height="420" Width="550" ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="机器码" FontSize="14" Foreground="#333" Margin="0,0,0,5"/>
            <TextBox x:Name="MachineCodeTextBox" Height="36" FontSize="13" Padding="8,6"
                     BorderBrush="#7163ba" BorderThickness="1.5" Background="#fafafa"
                     TextWrapping="Wrap" Margin="0,0,0,15"/>

            <TextBlock Text="到期日期" FontSize="14" Foreground="#333" Margin="0,0,0,5"/>
            <DatePicker x:Name="ExpiryDatePicker" Height="36" FontSize="13"
                        Margin="0,0,0,15" VerticalAlignment="Center"/>

            <Button x:Name="GenerateButton" Content="生成许可证" Height="40" FontSize="14"
                    Background="#7163ba" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="GenerateButton_Click" Margin="0,0,0,15">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5a5080"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <Border Background="#f5f5f5" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                <TextBox x:Name="ResultTextBox" Text="" FontSize="12" Foreground="#444"
                         TextWrapping="Wrap" FontFamily="Consolas"
                         IsReadOnly="True" BorderThickness="0" Background="Transparent"
                         MinHeight="50"/>
            </Border>

            <Button x:Name="ExportButton" Content="导出 .lic 文件" Height="36" FontSize="13"
                    Background="#444" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="ExportButton_Click" IsEnabled="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#333"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <TextBlock x:Name="MessageLabel" Text="" FontSize="12" Foreground="#d9534f"
                       Margin="0,5,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
