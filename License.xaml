<Page x:Class="UnlockWarning.License"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:UnlockWarning"
      mc:Ignorable="d"
      Title="License" Height="716" Width="1106">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">
            <TextBlock Text="机器码" FontSize="16" Foreground="#333" Margin="0,0,0,10"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="MachineCodeTextBox" Grid.Column="0" Height="36" FontSize="13"
                         IsReadOnly="True" BorderBrush="#7163ba" BorderThickness="1.5"
                         Background="#fafafa" FontFamily="Consolas" Padding="8,6"/>
                <Button Grid.Column="2" Content="复制" Height="36" FontSize="13"
                        Background="#7163ba" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="CopyMachineCode_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#5a5080"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <Border Background="#f5f5f5" CornerRadius="10" Padding="12" Margin="0,0,0,15">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="状态：" FontSize="14" Foreground="#555"/>
                        <TextBlock x:Name="StatusLabel" Text="未激活" FontSize="14" Foreground="#d9534f"
                                   FontWeight="Bold" Margin="5,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="有效期至：" FontSize="14" Foreground="#555"/>
                        <TextBlock x:Name="ExpiryLabel" Text="—" FontSize="14" Foreground="#333" Margin="5,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="序列号" FontSize="16" Foreground="#333" Margin="0,0,0,10"/>
            <TextBox x:Name="SerialTextBox" Height="36" FontSize="14" Padding="8,6"
                     BorderBrush="#7163ba" BorderThickness="1.5" Background="#fafafa"
                     TextChanged="SerialTextBox_TextChanged" Margin="0,0,0,10"/>
            <TextBlock x:Name="SerialStatusLabel" Text="" FontSize="12"
                       Margin="0,0,0,15" Foreground="#aaa"/>

            <TextBlock Text="许可证文件 (.lic)" FontSize="16" Foreground="#333" Margin="0,0,0,10"/>
            <Grid Margin="0,0,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="LicPathTextBox" Grid.Column="0" Height="36" FontSize="12"
                         IsReadOnly="True" BorderBrush="#7163ba" BorderThickness="1.5"
                         Background="#fafafa" Padding="8,6" VerticalContentAlignment="Center"/>
                <Button Grid.Column="2" Content="选择文件" Height="36" FontSize="13"
                        Background="#7163ba" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="ImportFile_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#5a5080"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>
            <TextBlock x:Name="LicStatusLabel" Text="" FontSize="12"
                       Margin="0,0,0,15" Foreground="#aaa"/>

            <Button x:Name="ActivateButton" Content="激活" Height="40" FontSize="14"
                    Background="#7163ba" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="ActivateButton_Click" IsEnabled="False">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5a5080"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#bbb"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <TextBlock x:Name="MessageLabel" Text="" FontSize="13" Foreground="#d9534f"
                       Margin="0,10,0,0" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Page>
