<Page x:Class="UnlockWarning.Sha256StringPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:UnlockWarning"
      mc:Ignorable="d"
      Title="Sha256StringPage" Height="716" Width="1106">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="500">
            <TextBlock Text="输入字符串" FontSize="16" Foreground="#333" Margin="0,0,0,10"/>
            <TextBox x:Name="InputTextBox" Height="36" FontSize="14" Padding="8,6" Margin="0,0,0,10"
                     BorderBrush="#7163ba" BorderThickness="1.5" Background="#fafafa"/>
            <Button x:Name="ComputeButton" Content="计算 SHA256" Height="40" FontSize="14"
                    Background="#7163ba" Foreground="White" BorderThickness="0"
                    Cursor="Hand" Click="ComputeButton_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#5a5080"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Border Background="#f5f5f5" CornerRadius="10" Padding="12" Margin="0,15,0,0">
                <TextBox x:Name="ResultLabel" Text="" FontSize="13" Foreground="#444"
                         TextWrapping="Wrap" FontFamily="Consolas"
                         IsReadOnly="True" BorderThickness="0" Background="Transparent"/>
            </Border>
        </StackPanel>
    </Grid>
</Page>
